<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Login</title>
  </head>
  <body>
    <h1>OnlyUserActivity</h1>
    <% if (error) { %>
      <div><%= error %></div>
    <% } %>
    <form method="post" action="/login">
      <div>
        <label>Username</label>
        <input name="username" />
      </div>
      <div>
        <label>Password</label>
        <input name="password" type="password" />
      </div>
      <button type="submit">Login</button>
    </form>
  </body>
</html>
