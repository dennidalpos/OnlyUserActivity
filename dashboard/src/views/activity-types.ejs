<!doctype html>
<html>
  <head>
    <meta charset="utf-8" />
    <title>Activity Types</title>
  </head>
  <body>
    <h1>Activity Types</h1>
    <% if (error) { %>
      <div><%= error %></div>
    <% } %>
    <form method="post" action="/activity-types">
      <textarea name="items" rows="10" cols="50"><% types.items.forEach(function(item){ %><%= item.id %>,<%= item.label %>
<% }) %></textarea>
      <div>
        <button type="submit">Save</button>
      </div>
    </form>
    <a href="/">Back</a>
  </body>
</html>
